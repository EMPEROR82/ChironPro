{
  "name": "chiron-extension",
  "displayName": "ChironPro",
  "description": "course-project",
  "version": "2.0.1",
  "icon": "./icons/wmremove-transformed.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/client/client.js",
  "activationEvents": [
    "onLanguage:chiron",
    "onCommand:chiron.runFile"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/EMPEROR82/ChironPro"
  },
  "contributes": {
    "commands": [
      {
        "command": "chiron.runFile",
        "title": "Run Chiron File",
        "icon": "$(play-circle)",
        "category": "Chiron"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "chiron.runFile",
          "when": "resourceExtname == '.tl'",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "chiron.runFile",
          "when": "resourceExtname == '.tl'",
          "group": "chiron@1"
        }
      ],
      "commandPalette": [
        {
          "command": "chiron.runFile",
          "when": "resourceExtname == '.tl'"
        }
      ]
    },
    "keybindings": [
      {
        "command": "chiron.runFile",
        "key": "f5",
        "when": "editorLangId == chiron"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Chiron",
      "properties": {
        "chiron.coreDir": {
          "type": "string",
          "default": "",
          "description": "Absolute path to ChironCore. If empty, extension will use bundled ChironCore."
        },
        "chiron.turtleColor": {
          "type": "string",
          "default": "green",
          "format": "color-hex",
          "description": "Color of the turtle"
        },
        "chiron.penColor": {
          "type": "string",
          "default": "blue",
          "format": "color-hex",
          "description": "Color of the drawing lines"
        },
        "chiron.backgroundColor": {
          "type": "string",
          "default": "white",
          "format": "color-hex",
          "description": "Background color of the canvas"
        },
        "chiron.moveSpeed": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 50,
          "description": "Animation speed of the turtle in the Webview panel (pixels per frame)."
        }
      }
    },
    "languages": [
      {
        "id": "chiron",
        "aliases": [
          "Chiron",
          "chiron"
        ],
        "extensions": [
          ".tl"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/wmremove-transformed.png",
          "dark": "./icons/wmremove-transformed.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "chiron",
        "scopeName": "source.chiron",
        "path": "./syntaxes/chiron.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "chiron",
        "path": "./snippets.json"
      }
    ]
  },
  "dependencies": {
    "antlr4ts": "^0.5.0-alpha.4",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.110.0",
    "antlr4ts-cli": "^0.5.0-alpha.4",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "antlr": "antlr4ts-cli -visitor -o server/antlr server/grammar/tlang.g4",
    "compile": "tsc -p ."
  },
  "publisher": "EMPEROR82"
}
